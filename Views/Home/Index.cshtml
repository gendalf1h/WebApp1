@{
    ViewData["Title"] = "Главная";
}

<section class="hero">
    <div class="container hero-wrapper">
        <div class="hero-text">
        <h1>Платформа обучения программированию</h1>

        <p>
            Изучай разработку, читай статьи и проходи курсы от практиков
        </p>

        <div class="hero-buttons">

            <a asp-controller="Product" asp-action="Index" class="btn btn-primary">
                 Смотреть курсы
            </a>

            <a asp-controller="Article" asp-action="Index" class="btn btn-dark">
                 Читать статьи
            </a>

        </div>
        </div>

        <div class="hero-image">
            <img src="~/images/laptop.jpg" alt="hero" />
        </div>

    </div>

</section>

