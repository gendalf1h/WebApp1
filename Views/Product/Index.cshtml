@model List<ProductCardVm>

<h1>Курсы программирования</h1>

<div class="products">
    @foreach(var product in Model)
    {
        <div class="card">
            <a asp-controller="Product"
            asp-action="Details"
            asp-route-id="@product.Id">
        
                <img src = "@product.ImageUrl" width="200" />
                <h3>@product.Title</h3>
        </a>
        </div>
    }
</div>